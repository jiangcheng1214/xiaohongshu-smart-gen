{
  "code": "finance",
  "name": "金融",
  "generation_mode": "strict",
  "persona_id": "finance",
  "content_research": {
    "queries": [
      {
        "template": "{topic} latest news today {year}",
        "purpose": "获取最新市场动态和数据",
        "required": true
      },
      {
        "template": "{topic} analysis forecast {year}",
        "purpose": "获取分析和预测"
      }
    ],
    "extract_instructions": {
      "data_points": "Extract key financial data points and numbers",
      "timestamps": "Extract data timestamps"
    }
  },
  "content_validation": {
    "rules": [
      {"id": "has_title_subtitle", "description": "title 4-8字，subtitle 8-15字"},
      {"id": "length_in_range", "params": {"min": 400, "max": 600}},
      {"id": "no_forbidden_expressions", "forbidden": ["值得注意的是", "综上所述", "然而", "此外", "另外", "一方面", "另一方面", "总而言之", "显而易见"]},
      {"id": "no_bullet_points"},
      {"id": "has_data_points"},
      {"id": "follows_structure"},
      {"id": "topic_relevance"}
    ],
    "min_score": 5,
    "max_retries": 3
  },
  "keywords": [
    "美联储",
    "利率",
    "A股",
    "港股",
    "美股",
    "基金",
    "理财",
    "量化",
    "通胀",
    "央行",
    "股票",
    "财报",
    "投资",
    "交易"
  ],
  "content_structure": {
    "min_length": 400,
    "max_length": 600,
    "paragraphs": [
      {
        "order": 1,
        "type": "hook",
        "name": "开篇钩子",
        "length": "1-2句",
        "instruction": "直接抛结论，不要铺垫"
      },
      {
        "order": 2,
        "type": "body",
        "name": "核心观点",
        "length": "50-80字",
        "instruction": "这是什么，为什么重要，数据驱动"
      },
      {
        "order": 3,
        "type": "body",
        "name": "财务数据",
        "length": "60-100字",
        "instruction": "具体数字、同比环比、时间戳，必须解释数据含义"
      },
      {
        "order": 4,
        "type": "body",
        "name": "业务拆解",
        "length": "60-100字",
        "instruction": "哪个业务在涨，为什么，占比"
      },
      {
        "order": 5,
        "type": "body",
        "name": "估值分析",
        "length": "50-80字",
        "instruction": "贵不贵，跟同类比，历史分位"
      },
      {
        "order": 6,
        "type": "body",
        "name": "催化剂风险",
        "length": "50-80字",
        "instruction": "什么会推动/拖累股价"
      },
      {
        "order": 7,
        "type": "body",
        "name": "实战建议",
        "length": "40-60字",
        "instruction": "这对交易意味着什么，什么时候买卖"
      },
      {
        "order": 8,
        "type": "cta",
        "name": "关注引导",
        "length": "1-2句",
        "instruction": "数据思维、深度认知、持续分享，每次原创"
      },
      {
        "order": 9,
        "type": "tags",
        "name": "话题标签",
        "count": "5-8",
        "instruction": "#股票 #投资 #量化 等"
      }
    ],
    "requires_risk_warning": true,
    "requires_data_timestamp": true,
    "requires_sources": true
  },
  "title_template": {
    "patterns": [
      "{topic}：{核心观点}",
      "{topic}：{关键词}解析",
      "{topic}是{类比对象}",
      "说人话：{核心观点}"
    ],
    "max_length": 20,
    "style": "直接观点 + 关键信息",
    "separator": "："
  },
  "cover_config": {
    "logo_file": "finance.png",
    "background_prompt_template": "Professional modern color gradient background in elegant design, subtle floating  geometric shapes, flat style, 3:4 portrait, no text, no words, no letters, minimal tech aesthetic."
  }
}
