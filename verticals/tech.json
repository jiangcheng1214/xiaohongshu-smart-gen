{
  "code": "tech",
  "name": "科技",
  "generation_mode": "strict",
  "persona_id": "tech",
  "keywords": [
    "AI",
    "芯片",
    "手机",
    "电脑",
    "显卡",
    "ChatGPT",
    "苹果",
