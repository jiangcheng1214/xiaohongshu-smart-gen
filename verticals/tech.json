{
  "code": "tech",
  "name": "科技",
  "generation_mode": "strict",
  "persona_id": "tech",
  "content_research": {
    "queries": [
      {
        "template": "{topic} review latest {year}",
        "purpose": "获取最新评测和参数",
        "required": true
      },
      {
        "template": "{topic} specs price comparison {year}",
        "purpose": "获取规格和价格对比"
      }
    ],
    "extract_instructions": {
      "specs": "Extract key specifications",
      "price": "Extract current price"
    }
  },
  "content_validation": {
    "rules": [
      {"id": "has_title_subtitle", "description": "title 4-8字，subtitle 8-15字"},
      {"id": "length_in_range", "params": {"min": 380, "max": 580}},
      {"id": "no_forbidden_expressions", "forbidden": ["值得注意的是", "综上所述", "然而", "此外", "另外", "一方面", "另一方面", "完美诠释", "极致体验"]},
      {"id": "no_bullet_points"},
      {"id": "has_data_points"},
      {"id": "follows_structure"},
      {"id": "topic_relevance"}
    ],
    "min_score": 5,
    "max_retries": 3
  },
  "keywords": [
    "AI",
    "芯片",
    "手机",
    "电脑",
    "显卡",
    "ChatGPT",
    "苹果",
    "华为",
    "小米",
    "笔记本",
    "平板",
    "智能手表",
    "耳机",
    "5G",
    "折叠屏"
  ],
  "content_structure": {
    "min_length": 380,
    "max_length": 580,
    "paragraphs": [
      {
        "order": 1,
        "type": "hook",
        "name": "开篇钩子",
        "length": "1-2句",
        "instruction": "直接说结论或抛问题"
      },
      {
        "order": 2,
        "type": "body",
        "name": "产品定位",
        "length": "40-60字",
        "instruction": "这是什么产品，什么定位，什么价格"
      },
      {
        "order": 3,
        "type": "body",
        "name": "核心参数",
        "length": "60-100字",
        "instruction": "处理器、内存、屏幕等核心参数"
      },
      {
        "order": 4,
        "type": "body",
        "name": "实际体验",
        "length": "60-100字",
        "instruction": "实际使用感受，流畅度，续航，信号"
      },
      {
        "order": 5,
        "type": "body",
        "name": "竞品对比",
        "length": "50-80字",
        "instruction": "和竞品对比，优势劣势"
      },
      {
        "order": 6,
        "type": "body",
        "name": "价格分析",
        "length": "40-60字",
        "instruction": "值不值，性价比，同类对比"
      },
      {
        "order": 7,
        "type": "body",
        "name": "购买建议",
        "length": "1-2句",
        "instruction": "适合谁，什么时候买"
      },
      {
        "order": 8,
        "type": "cta",
        "name": "关注引导",
        "length": "1-2句",
        "instruction": "真实评测、参数党、持续分享，每次原创"
      },
      {
        "order": 9,
        "type": "tags",
        "name": "话题标签",
        "count": "5-8",
        "instruction": "#数码 #科技 #评测 等"
      }
    ],
    "requires_risk_warning": false,
    "requires_data_timestamp": false,
    "requires_sources": true
  },
  "title_template": {
    "patterns": [
      "{topic}：真实评测",
      "{topic}：值不值得买？",
      "{topic}：参数党进",
      "{topic}：上手{天数}天感受"
    ],
    "max_length": 20,
    "style": "产品名 + 问题/结论",
    "separator": "："
  },
  "cover_config": {
    "logo_file": "default.png",
    "aspect_ratio": "3:4",
    "background_prompt_template": "高端科技产品大片实拍图，官方发布会级别的产品摄影 {product_name} 居中构图，产品本身清晰锐利，金属/玻璃质感完美呈现，细节可见，表面反光自然真实，屏幕或指示灯有微弱发光效果，产品角度略微倾斜展示立体感，动态虚化背景营造速度感和冲击力，深色渐变背景带有微妙的光束扫过，高对比度戏剧性光影，左下角或右下角悬浮显示关键参数文字：{key_specs}，文字采用细线条现代字体，半透明白色带发光效果，整体色调冷峻科技感（深蓝/黑/银），专业棚拍灯光，主光源从左上45度打光，轮廓光勾勒产品边缘，高光不过曝，暗部有细节，8K超高清分辨率，商业广告级质感，无水印无logo，产品本身无遮挡",
    "prompt_variables": {
      "product_name": {
        "source": "extract_from_topic",
        "description": "从 topic 提取产品名称，如 'iPhone 17 Pro'、'RTX 5090'、'fujifilm x100vi'"
      },
      "key_specs": {
        "source": "web_search",
        "query": "{topic} key specs main features {year}",
        "extraction_mode": "llm",
        "max_length": 25,
        "description": "获取产品核心参数，返回2-3个最关键的规格，用斜杠分隔。例：'骁龙8Gen3/16GB/2K屏' 或 'RTX4090/24GB/DLSS3'",
        "default": ""
      }
    }
  }
}
