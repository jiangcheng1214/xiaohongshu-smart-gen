{
  "code": "beauty",
  "name": "美妆",
  "generation_mode": "strict",
  "persona_id": "beauty",
  "content_research": {
    "queries": [
      {
        "template": "{topic} review latest {year}",
        "purpose": "获取最新测评和体验",
        "required": true
      },
      {
        "template": "{topic} ingredients comparison {year}",
        "purpose": "获取成分和对比"
      }
    ],
    "extract_instructions": {
      "ingredients": "Extract key ingredients",
      "price": "Extract current price"
    }
  },
  "content_validation": {
    "rules": [
      {"id": "has_title_subtitle", "description": "title 4-8字，subtitle 8-15字"},
      {"id": "length_in_range", "params": {"min": 350, "max": 550}},
      {"id": "no_forbidden_expressions", "forbidden": ["值得注意的是", "综上所述", "然而", "此外", "另外", "一方面", "另一方面", "完美融合", "绝佳体验"]},
      {"id": "no_bullet_points"},
      {"id": "has_data_points"},
      {"id": "follows_structure"},
      {"id": "topic_relevance"}
    ],
    "min_score": 5,
    "max_retries": 3
  },
  "keywords": [
    "口红",
    "粉底液",
    "精华",
    "面霜",
    "防晒",
    "护肤",
    "彩妆",
    "眼影",
    "腮红",
    "睫毛膏",
    "妆前乳",
    "散粉",
    "气垫",
    "遮瑕"
  ],
  "content_structure": {
    "min_length": 350,
    "max_length": 550,
    "paragraphs": [
      {
        "order": 1,
        "type": "hook",
        "name": "开篇钩子",
        "length": "1-2句",
        "instruction": "直接说结论或制造悬念"
      },
      {
        "order": 2,
        "type": "body",
        "name": "产品定位",
        "length": "40-60字",
        "instruction": "这是什么产品，什么牌子，什么价位"
      },
      {
        "order": 3,
        "type": "body",
        "name": "质地体验",
        "length": "60-100字",
        "instruction": "质地描述，上脸感受，味道，延展性"
      },
      {
        "order": 4,
        "type": "body",
        "name": "效果表现",
        "length": "60-100字",
        "instruction": "实际效果，持妆度，遮瑕力，显色度"
      },
      {
        "order": 5,
        "type": "body",
        "name": "肤质适配",
        "length": "40-60字",
        "instruction": "什么肤质适合/不适合，干皮油皮"
      },
      {
        "order": 6,
        "type": "body",
        "name": "性价比",
        "length": "40-60字",
        "instruction": "值不值，有平替吗，同类对比"
      },
      {
        "order": 7,
        "type": "body",
        "name": "购买建议",
        "length": "1-2句",
        "instruction": "推荐/不推荐，适合谁"
      },
      {
        "order": 8,
        "type": "cta",
        "name": "关注引导",
        "length": "1-2句",
        "instruction": "真实测评、避坑指南、持续分享，每次原创"
      },
      {
        "order": 9,
        "type": "tags",
        "name": "话题标签",
        "count": "5-8",
        "instruction": "#美妆 #护肤 #测评 等"
      }
    ],
    "requires_risk_warning": false,
    "requires_data_timestamp": false,
    "requires_sources": false
  },
  "title_template": {
    "patterns": [
      "{topic}：真实测评",
      "{topic}：值不值得买？",
      "{topic}：踩雷还是真香",
      "{topic}：使用{天数}天感受"
    ],
    "max_length": 20,
    "style": "产品名 + 结论/疑问",
    "separator": "："
  },
  "cover_config": {
    "logo_file": "default.png",
    "aspect_ratio": "1:1",
    "background_prompt_template": "一位 20 多岁的超可爱日本女性，业余智能手机摄影风格，分辨率略低，构图略显凌乱 柔和的双眼皮略带圆润，打造出友善的大眼睛，自然的平行双眼皮褶皱宽度适中，温暖的深棕色虹膜传达出温柔和暖意，带有自然的眼神光，眼下略微浮肿的自然卧蚕捕捉着光线，自然的直眉毛，眉弓柔和，粗细适中，小巧可爱的鼻子，鼻梁自然低平，鼻尖圆润柔和，上唇略薄，下唇丰满，打造出可爱的嘴巴，呈现自然的粉珊瑚色和甜美慵懒的表情，脸颊圆润柔和，带有自然的红晕，脸部线条流畅呈椭圆形，下巴小巧圆润，半透明的暖象牙色肌肤，散发着自然光泽 蓬松凌乱的齐肩半长发，侧分刘海 淡粉色丝绸吊带背心，细肩带，胸部有蕾丝细节，露背设计，搭配同款丝绸短裤 坐在床上，一条腿弯曲，手指穿过头发，头部微微倾斜 卧室里有白色床单和枕头，窗户透进柔和的早晨自然光，背景虚化，充满生活气息的私密空间 自然妆容：无眼线，睫毛膏轻薄，上睫毛自然分明，眼影是薄薄的暖米色粉色晕染，唇色是薄薄的珊瑚粉，脸颊扫上柔和自然的桃色腮红，肌肤呈现透亮光泽感"
  }
}
